{
  "_comment": "数据Agent权限规则配置",
  "_description": "数据Agent的权限规则，定义各操作的权限校验逻辑",
  "_agentType": "data",
  "_version": "1.0.0",

  "permissionRules": [
    {
      "ruleId": "data-query-self",
      "ruleName": "数据查询-本人数据",
      "condition": "查询",
      "checkLogic": "用户登录即可",
      "interceptAction": "您没有权限查询数据"
    },
    {
      "ruleId": "data-query-other",
      "ruleName": "数据查询-他人数据",
      "condition": "查询",
      "checkLogic": "查询他人数据:需要管理员",
      "interceptAction": "您没有权限查询他人的数据"
    },
    {
      "ruleId": "data-export",
      "ruleName": "数据导出",
      "condition": "查询",
      "checkLogic": "用户登录即可",
      "interceptAction": "您没有权限导出数据"
    },
    {
      "ruleId": "data-report",
      "ruleName": "报表生成",
      "condition": "创建",
      "checkLogic": "用户登录即可",
      "interceptAction": "您没有权限生成报表"
    },
    {
      "ruleId": "data-statistics",
      "ruleName": "数据统计",
      "condition": "查询",
      "checkLogic": "用户登录即可",
      "interceptAction": "您没有权限查看统计数据"
    }
  ]
