{
  "_comment": "会议Agent权限规则配置",
  "_description": "会议Agent的权限规则，定义各操作的权限校验逻辑",
  "_agentType": "meeting",
  "_version": "1.0.0",

  "permissionRules": [
    {
      "ruleId": "meeting-query-self",
      "ruleName": "会议查询-查询本人",
      "condition": "查询",
      "checkLogic": "用户登录即可",
      "interceptAction": "您没有权限查询会议"
    },
    {
      "ruleId": "meeting-query-other",
      "ruleName": "会议查询-查询他人",
      "condition": "查询",
      "checkLogic": "查询他人数据:需要管理员",
      "interceptAction": "您无权查询他人的会议，普通用户只能查询自己的会议"
    },
    {
      "ruleId": "meeting-create",
      "ruleName": "会议创建",
      "condition": "创建",
      "checkLogic": "用户登录即可",
      "interceptAction": "您没有权限创建会议"
    },
    {
      "ruleId": "meeting-update-own",
      "ruleName": "会议更新-自己的会议",
      "condition": "更新",
      "checkLogic": "用户登录即可",
      "interceptAction": "您没有权限更新此会议"
    },
    {
      "ruleId": "meeting-update-other",
      "ruleName": "会议更新-他人的会议",
      "condition": "更新",
      "checkLogic": "查询他人数据:需要管理员",
      "interceptAction": "您没有权限更新他人的会议"
    },
    {
      "ruleId": "meeting-cancel-own",
      "ruleName": "会议取消-自己的会议",
      "condition": "取消",
      "checkLogic": "用户登录即可",
      "interceptAction": "您没有权限取消此会议"
    },
    {
      "ruleId": "meeting-cancel-other",
      "ruleName": "会议取消-他人的会议",
      "condition": "取消",
      "checkLogic": "查询他人数据:需要管理员",
      "interceptAction": "您没有权限取消他人的会议"
    },
    {
      "ruleId": "meeting-detail",
      "ruleName": "会议详情",
      "condition": "查询",
      "checkLogic": "用户登录即可",
      "interceptAction": "您没有权限查看会议详情"
    }
  ]
}
