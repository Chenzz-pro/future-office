# 数据库配置（可选）
# 如果配置了这些环境变量，应用启动时会自动连接数据库
# 适用于生产环境或需要持久化数据库连接的场景

# 数据库主机地址
DB_HOST=localhost

# 数据库端口
DB_PORT=3306

# 数据库名称
DB_NAME=future_office

# 数据库用户名
DB_USER=root

# 数据库密码
DB_PASSWORD=your_password_here

# 注意事项：
# 1. 环境变量的优先级低于配置文件（.db-config.json）
# 2. 如果配置文件存在，会优先使用配置文件
# 3. 如果两者都不存在，访问系统时会提示需要初始化
# 4. 配置文件保存在项目根目录下的 .db-config.json
